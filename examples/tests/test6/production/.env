NODE_ENV=production
PORT=8080
HOST=0.0.0.0

# Database — use connection pooler (PgBouncer) in production
DATABASE_URL=postgres://user:password@db.internal:5432/myapp_prod
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20
DATABASE_SSL=true

# Redis — used for sessions and rate limiting
REDIS_URL=redis://redis.internal:6379
REDIS_TLS=true

# Secrets — rotate every 90 days
SESSION_SECRET=<generate with: openssl rand -base64 64>
JWT_SECRET=<generate with: openssl rand -base64 64>
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# CORS
CORS_ORIGINS=https://app.example.com,https://www.example.com
